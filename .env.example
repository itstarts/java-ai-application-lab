# Default provider convention for future stages.
# Do not put real secrets in this file.

AI_PROVIDER=mock
AI_CHAT_MODEL=mock-chat
AI_BASE_URL=
AI_API_KEY=replace-with-your-local-secret
AI_REQUEST_TIMEOUT=30s

# OpenAI-compatible provider example. Enable only after mock provider tests pass.
# AI_PROVIDER=openai
# AI_CHAT_MODEL=gpt-4.1-mini
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=replace-with-your-local-secret
# AI_REQUEST_TIMEOUT=30s

# Local model option for experiments.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# App settings.
SERVER_PORT=8080
